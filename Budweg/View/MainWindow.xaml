<Window x:Class="Budweg.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Budweg"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="500" Height="200">
            <TextBlock Text="Registrer medarbejder-ID"
                       FontSize="20"
                       TextAlignment="Center"
                       Margin="0,0,0,20" Width="231"/>

            <TextBox Text="{Binding EmployeeIdText, UpdateSourceTrigger=PropertyChanged}"
                     Height="30"
                     Margin="0,0,0,10"/>

            <Button Content="Tjek ind" Click="CheckIn_Click"
                    Height="35"
                    Margin="0,0,0,10"/>

            <TextBlock Text="{Binding Message}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>

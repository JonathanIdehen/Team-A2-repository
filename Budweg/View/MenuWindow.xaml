<Window x:Class="Budweg.View.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Budweg.View"
        mc:Ignorable="d"
        Title="MenuWindow" Height="450" Width="800">
    <Grid>
        <TabControl>

            <TabItem Header="Registrer bremsekaliber">
                <Grid Margin="20">
                    <StackPanel Width="350" HorizontalAlignment="Left" VerticalAlignment="Top">

                        <TextBlock Text="BremsekaliberID:" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtCaliperId" Height="30" Margin="0,0,0,15"/>

                        <TextBlock Text="Varenummer:" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtItemNumber" Height="30" Margin="0,0,0,15"/>

                        <Button Content="Vis type"
                    Height="35"
                    Margin="0,0,0,15"
                    Click="ShowCaliperType_Click"/>

                        <TextBlock Text="Bremsekalibertype:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock x:Name="txtCaliperTypeResult"
                       Text=""
                       Margin="0,0,0,20"
                       FontSize="16"/>

                        <Button Content="Gem"
                    Height="35"
                    Click="SaveCaliper_Click"/>

                        <TextBlock x:Name="txtCaliperMessage"
                       Margin="0,20,0,0"
                       TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Registrer indgangskontrol">
                <Grid>
                    <TextBlock Text="Her skal indgangskontrol laves"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="20"/>
                </Grid>
            </TabItem>

            <TabItem Header="Registrer slutkontrol">
                <Grid>
                    <TextBlock Text="Her skal slutkontrol laves"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="20"/>
                </Grid>
            </TabItem>

            <TabItem Header="Få historik over bremsekalibre">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="BremsekaliberID:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
                        <TextBox x:Name="txtHistoryCaliperId"
                     Width="150"
                     Height="30"
                     Margin="0,0,10,0"/>
                        <Button Content="Søg"
                    Width="100"
                    Height="30"
                    Click="SearchHistory_Click"
                    Margin="0,0,10,0"/>
                        <Button Content="Vis seneste"
                    Width="100"
                    Height="30"
                    Click="ShowLatestHistory_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="txtHistoryMessage"
                   Grid.Row="1"
                   Margin="0,0,0,15"
                   TextWrapping="Wrap"/>

                    <DataGrid x:Name="dgHistory"
                  Grid.Row="2"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>
                </Grid>
            </TabItem>



        </TabControl>
    </Grid>
</Window>
